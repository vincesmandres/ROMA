# ROMA - configuración local
# Copia este archivo como .env.local y completa únicamente los valores necesarios.

# Supabase: proyecto de datos y Edge Functions
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Solo servidor. Nunca exponer en variables NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
# Compatibilidad con integraciones que aún exponen la clave anon:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI: análisis estructurado de reportes y generación de briefs
OPENAI_API_KEY=
OPENAI_MODEL=

# WhatsApp Cloud API de Meta: se activará después del dashboard
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_URL=

# Telegram: canal operativo principal del MVP
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CHAT_ID=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Semaphore: grupo de participantes y verificación ZK
SEMAPHORE_GROUP_ID=
SEMAPHORE_NETWORK=sepolia

# Mapa: usar un proveedor de tiles con política compatible con producción
NEXT_PUBLIC_MAP_STYLE_URL=
